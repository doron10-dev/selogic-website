# Form submission gate — keep false until Resend domain is verified and env is set on Vercel.
FORMS_ENABLED=false

# Resend (server only — never expose to client)
RESEND_API_KEY=

# Verified sender on selogic.co.il (Resend domain verification required)
MAIL_FROM=forms@selogic.co.il

# Production: info@selogic.co.il | Preview: dev+forms@selogic.co.il (or personal test inbox)
MAIL_TO=info@selogic.co.il
